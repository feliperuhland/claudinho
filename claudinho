#!/bin/bash
set -euo pipefail

IMAGE="ghcr.io/feliperuhland/claudinho-code"
PWD_HASH=$(printf '%s' "$PWD" | (sha256sum 2>/dev/null || shasum -a 256) | cut -c1-12)
CONTAINER_NAME="claudinho-${PWD_HASH}"

if ! docker info > /dev/null 2>&1; then
  echo "Error: Docker daemon is not running." >&2
  exit 1
fi

# Pull latest image; compare digests to detect updates
BEFORE=$(docker inspect --format '{{.Id}}' "$IMAGE" 2>/dev/null || true)
docker pull "$IMAGE" > /dev/null 2>&1 || true
AFTER=$(docker inspect --format '{{.Id}}' "$IMAGE" 2>/dev/null || true)

NEW_IMAGE=false
if [ -n "$BEFORE" ] && [ -n "$AFTER" ] && [ "$BEFORE" != "$AFTER" ]; then
  echo "New image available, updating..."
  NEW_IMAGE=true
fi

# If container exists and is using an outdated image, stop and remove it
if docker inspect "$CONTAINER_NAME" &>/dev/null; then
  CONTAINER_IMAGE=$(docker inspect --format '{{.Image}}' "$CONTAINER_NAME")
  CURRENT_IMAGE=$(docker inspect --format '{{.Id}}' "$IMAGE")
  if [ "$CONTAINER_IMAGE" != "$CURRENT_IMAGE" ] || [ "$NEW_IMAGE" = "true" ]; then
    echo "Container is using an outdated image, recreating..."
    STATUS=$(docker inspect --format '{{.State.Status}}' "$CONTAINER_NAME")
    if [ "$STATUS" = "running" ]; then
      docker stop "$CONTAINER_NAME"
    fi
    docker rm "$CONTAINER_NAME"
  fi
fi

_run_container() {
  docker run -it \
    --name "$CONTAINER_NAME" \
    --security-opt no-new-privileges \
    --memory=4g \
    --pids-limit=512 \
    -v "${PWD}:/home/ubuntu/workspace" \
    -v "${HOME}/.claude:/home/ubuntu/.claude" \
    -v "${HOME}/.claude.json:/home/ubuntu/.claude.json:ro" \
    "$IMAGE" \
    "$@"
}

if docker inspect "$CONTAINER_NAME" &>/dev/null; then
  STATUS=$(docker inspect --format '{{.State.Status}}' "$CONTAINER_NAME")
  if [ "$STATUS" = "running" ]; then
    docker exec -it "$CONTAINER_NAME" claude
  else
    docker start -ai "$CONTAINER_NAME"
  fi
else
  _run_container "$@"
fi
